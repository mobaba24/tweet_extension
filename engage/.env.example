# Copy to .env and fill in. NEVER commit .env (it's gitignored).

# Reply engine
ANTHROPIC_API_KEY=sk-ant-...
ENGAGE_MODEL=claude-opus-4-8           # or claude-sonnet-4-6 / claude-haiku-4-5 for volume
ENGAGE_PERSONA=a friendly, respectful person who leaves short, genuine, on-topic comments

# Relevance: only engage with posts matching these (comma-separated). Empty = engage with all.
NICHE_KEYWORDS=

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-...
TG_REPLY_LANG=Persian                   # default caption language (toggle in-bot)
TG_MIN_SECONDS_PER_USER=8
ADMIN_IDS=255179213                     # comma-separated Telegram user ids for admin commands
FREE_PER_DAY=3                          # free captions per user per day
TASK_BONUS=3                            # credits granted per completed task (join channel / start bot)

# X official API (Phase 3) — from your approved developer app
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
X_AUTONOMOUS=false                     # keep false; review-first
MAX_REPLIES_PER_HOUR=8
MAX_REPLIES_PER_DAY=40
